rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ══════════════════════════════════════════════════════
    // USERS — branje lastnega profila, pisanje samo preko backend-a
    // ══════════════════════════════════════════════════════
    match /users/{userId} {
      // Own profile: full read.
      // Other authenticated users: read allowed. PublicProfile.fromFirestore
      // only surfaces safe fields (name, age, photoUrls, hobbies, lookingFor,
      // isTraveler) — no PII. Write protection below keeps sensitive fields
      // (isPremium, isAdmin, activeGymId, gymModeUntil, activeEventId)
      // backend-only regardless of who can read.
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId && !request.resource.data.keys().hasAny(['isPremium', 'isAdmin', 'activeGymId', 'gymModeUntil', 'activeEventId', 'ageConfirmed', 'ageConfirmedAt']);
      allow update: if request.auth != null && request.auth.uid == userId && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['isPremium', 'isAdmin', 'activeGymId', 'gymModeUntil', 'activeEventId', 'ageConfirmed', 'ageConfirmedAt']);
    }

    match /drafts/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ══════════════════════════════════════════════════════
    // WAITLIST — javna prijava na čakalno listo
    // ══════════════════════════════════════════════════════
    match /waitlist/{document=**} {
      allow create: if 
        request.resource.data.email is string &&
        request.resource.data.email.matches('.+@.+\\..+') &&
        request.resource.data.source in ['website', 'website-undo'] &&
        request.resource.data.unsubscribeToken is string &&
        request.resource.data.subscribedAt is timestamp;
      allow read, write, update, delete: if false;
    }

    // ══════════════════════════════════════════════════════
    // MATCHES — branje dovoljeno le vpletenima (userIds array)
    // ══════════════════════════════════════════════════════
    match /matches/{matchId} {
      allow read: if request.auth != null &&
                    request.auth.uid in resource.data.userIds;
      // Edina dovoljena klient sprememba je seenBy (markMatchAsSeen po razkritju)
      allow update: if request.auth != null &&
                      request.auth.uid in resource.data.userIds &&
                      request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['seenBy']);
      allow create, delete: if false; // Izključno Cloud Function onWaveCreated
    }

    /// ══════════════════════════════════════════════════════
    // WAVES — stroga zasebnost, branje le lastnih izhodnih valov
    // ══════════════════════════════════════════════════════
    match /waves/{waveId} {
      allow read: if request.auth != null && resource.data.fromUid == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.fromUid == request.auth.uid;
      allow update, delete: if false;
    }

    // ══════════════════════════════════════════════════════
    // EVENTS — F2: Event Mode Matching
    // Branje dovoljeno vsem avtentificiranim (da preverijo aktiven event).
    // Pisanje je IZKLJUČNO Cloud Functions (admin-ustvarjeni eventi).
    // ══════════════════════════════════════════════════════
    match /events/{eventId} {
      // Authenticated users can read events to join them
      allow read: if request.auth != null;
      // Only Cloud Functions (no auth uid == service account) can write
      allow create, update, delete: if false;
    }

    // ══════════════════════════════════════════════════════
    // PROXIMITY — branje aktivnih uporabnikov za radar
    // ══════════════════════════════════════════════════════
    match /proximity/{userId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ══════════════════════════════════════════════════════
    // PROXIMITY EVENTS — BLE zapisuje, backend procesira
    // ══════════════════════════════════════════════════════
    match /proximity_events/{eventId} {
      allow write: if request.auth != null
        && request.resource.data.from == request.auth.uid
        && request.resource.data.keys().hasAll(['from', 'toDeviceId', 'rssi', 'timestamp', 'ttl'])
        && request.resource.data.rssi is int
        && request.resource.data.timestamp is timestamp;
      allow read: if false;
    }

    // ══════════════════════════════════════════════════════
    // SISTEMSKI DEL (Rate Limits, Idempotency, GDPR)
    // ══════════════════════════════════════════════════════
    match /rateLimits/{doc} {
      allow read, write: if false;
    }

    match /idempotencyKeys/{doc} {
      allow read, write: if false;
    }

    match /gdprRequests/{doc} {
      allow read: if request.auth != null && resource.data.uid == request.auth.uid;
      allow write: if false;
    }

    // ══════════════════════════════════════════════════════
    // DEFAULT DENY
    // ══════════════════════════════════════════════════════
    match /{document=**} {
      allow read, write: if false;
    }
  }
}