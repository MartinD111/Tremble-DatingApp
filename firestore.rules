rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ══════════════════════════════════════════════════════
    // USERS — branje lastnega profila, pisanje samo preko backend-a
    // ══════════════════════════════════════════════════════
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false; 
    }

    // ══════════════════════════════════════════════════════
    // MATCHES — branje dovoljeno le vpletenima (userIds array)
    // ══════════════════════════════════════════════════════
    match /matches/{matchId} {
      allow read: if request.auth != null &&
                    request.auth.uid in resource.data.userIds;
      // Edina dovoljena klient sprememba je seenBy (markMatchAsSeen po razkritju)
      allow update: if request.auth != null &&
                      request.auth.uid in resource.data.userIds &&
                      request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['seenBy']);
      allow create, delete: if false; // Izključno Cloud Function onWaveCreated
    }

    /// ══════════════════════════════════════════════════════
    // WAVES — stroga zasebnost, branje le lastnih izhodnih valov
    // ══════════════════════════════════════════════════════
    match /waves/{waveId} {
      allow read: if request.auth != null && resource.data.fromUid == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.fromUid == request.auth.uid;
      allow update, delete: if false;
    }

    // ══════════════════════════════════════════════════════
    // PROXIMITY — branje aktivnih uporabnikov za radar
    // ══════════════════════════════════════════════════════
    match /proximity/{userId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ══════════════════════════════════════════════════════
    // PROXIMITY EVENTS — BLE zapisuje, backend procesira
    // ══════════════════════════════════════════════════════
    match /proximity_events/{eventId} {
      allow write: if request.auth != null;
      allow read: if false;
    }

    // ══════════════════════════════════════════════════════
    // SISTEMSKI DEL (Rate Limits, Idempotency, GDPR)
    // ══════════════════════════════════════════════════════
    match /rateLimits/{doc} {
      allow read, write: if false;
    }

    match /idempotencyKeys/{doc} {
      allow read, write: if false;
    }

    match /gdprRequests/{doc} {
      allow read: if request.auth != null && resource.data.uid == request.auth.uid;
      allow write: if false;
    }

    // ══════════════════════════════════════════════════════
    // DEFAULT DENY
    // ══════════════════════════════════════════════════════
    match /{document=**} {
      allow read, write: if false;
    }
  }
}