rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function validCreateKeys() {
      return !request.resource.data.keys().hasAny([
        'isPremium',
        'isAdmin',
        'activeGymId',
        'gymModeUntil',
        'activeEventId',
        'ageConfirmed',
        'ageConfirmedAt'
      ]);
    }

    function validUpdateKeys() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny([
        'isPremium',
        'isAdmin',
        'activeGymId',
        'gymModeUntil',
        'activeEventId',
        'ageConfirmed',
        'ageConfirmedAt'
      ]);
    }

    function isWaveParticipant(data) {
      return signedIn() && (
        request.auth.uid == data.senderId ||
        request.auth.uid == data.receiverId ||
        request.auth.uid == data.fromUid ||
        request.auth.uid == data.toUid
      );
    }

    function isWaveSender(data) {
      return signedIn() && (
        request.auth.uid == data.senderId ||
        request.auth.uid == data.fromUid
      );
    }

    function isSessionParticipant(data) {
      return signedIn() && (
        request.auth.uid == data.senderId ||
        request.auth.uid == data.receiverId ||
        (data.keys().hasAny(['userIds']) && request.auth.uid in data.userIds)
      );
    }

    // USERS — own profile only.
    match /users/{userId} {
      allow read: if isSelf(userId);
      allow create: if isSelf(userId) && validCreateKeys();
      allow update: if isSelf(userId) && validUpdateKeys();
      allow delete: if isSelf(userId);
    }

    match /drafts/{userId} {
      allow read, write: if isSelf(userId);
    }

    // WAITLIST — public signup only.
    match /waitlist/{document=**} {
      allow create: if
        request.resource.data.email is string &&
        request.resource.data.email.matches('.+@.+\\..+') &&
        request.resource.data.source in ['website', 'website-undo'] &&
        request.resource.data.unsubscribeToken is string &&
        request.resource.data.subscribedAt is timestamp;
      allow read, write, update, delete: if false;
    }

    // MATCHES — participants only.
    match /matches/{matchId} {
      allow read: if signedIn() && request.auth.uid in resource.data.userIds;
      allow update: if signedIn() &&
                    request.auth.uid in resource.data.userIds &&
                    request.resource.data.diff(resource.data).affectedKeys()
                      .hasOnly(['seenBy']);
      allow create, delete: if false;
    }

    // WAVES — participants can read, only the sender can create, no mutation.
    match /waves/{waveId} {
      allow read: if isWaveParticipant(resource.data);
      allow create: if isWaveSender(request.resource.data);
      allow update, delete: if false;
    }

    // SESSIONS — participants can read, clients cannot write.
    match /sessions/{sessionId} {
      allow read: if isSessionParticipant(resource.data);
      allow create, update, delete: if false;
    }

    // EVENTS — authenticated read, backend-only writes.
    match /events/{eventId} {
      allow read: if signedIn();
      allow create, update, delete: if false;
    }

    // PROXIMITY — backend-readable only. Clients may write only their own
    // ephemeral geohash document; Admin SDK bypasses rules for Cloud Functions.
    match /proximity/{userId} {
      allow read: if false;
      allow write: if isSelf(userId);
    }

    // ACTIVE RUN CROSSES — involved users can read, backend-only writes.
    match /active_run_crosses/{docId} {
      allow read: if signedIn() && request.auth.uid in resource.data.userIds;
      allow create, update, delete: if false;
    }

    // PROXIMITY EVENTS — BLE writes, backend processes.
    match /proximity_events/{eventId} {
      allow write: if signedIn() &&
        request.resource.data.from == request.auth.uid &&
        request.resource.data.keys().hasAll(['from', 'toDeviceId', 'rssi', 'timestamp', 'ttl']) &&
        request.resource.data.rssi is int &&
        request.resource.data.timestamp is timestamp;
      allow read: if false;
    }

    match /rateLimits/{doc} {
      allow read, write: if false;
    }

    match /idempotencyKeys/{doc} {
      allow read, write: if false;
    }

    match /gdprRequests/{doc} {
      allow read: if signedIn() && resource.data.uid == request.auth.uid;
      allow write: if false;
    }

    // DEFAULT DENY
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
