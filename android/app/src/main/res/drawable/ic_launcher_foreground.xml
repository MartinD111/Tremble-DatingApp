<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive-icon foreground + themed (monochrome) layer for the launcher icon.
  Vector port of Logo/tremble_icon_clean_transparent.svg (white heart, no plate).

  Sized down on purpose: the heart bounding box (220-space x:34.4..186.72) is
  scaled by 0.29 -> ~44dp inside the 108dp adaptive canvas, i.e. ~61% of the
  72dp visible safe zone, leaving the breathing room shown in the brand icon.
  Group transform maps the heart's centre (110.56, 98.8 in 220-space) onto the
  canvas centre (54, 54): translate = 54 - centre*scale.

  Used for BOTH <foreground> and <monochrome> in launcher_icon.xml, so the
  Material You themed icon is pixel-aligned with the normal icon.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <group
        android:scaleX="0.29"
        android:scaleY="0.29"
        android:translateX="21.94"
        android:translateY="25.35">

        <!-- Main curve (left lobe) -->
        <path
            android:strokeColor="#FFFFFF"
            android:strokeWidth="11.2"
            android:strokeLineCap="round"
            android:strokeLineJoin="round"
            android:pathData="M101.6,166 C68,154.8 34.4,121.2 34.4,87.6 C34.4,48.4 68,31.6 101.6,65.2" />

        <!-- Outer wave (right lobe) -->
        <path
            android:strokeColor="#FFFFFF"
            android:strokeWidth="11.2"
            android:strokeLineCap="round"
            android:strokeLineJoin="round"
            android:pathData="M119.52,65.2 C153.12,31.6 186.72,48.4 186.72,87.6 C186.72,121.2 153.12,154.8 119.52,166" />

        <!-- Mid wave -->
        <path
            android:strokeColor="#FFFFFF"
            android:strokeWidth="11.2"
            android:strokeLineCap="round"
            android:strokeLineJoin="round"
            android:pathData="M119.52,93.2 C138.56,70.8 157.6,82 157.6,101.04 C157.6,118.96 138.56,134.64 119.52,143.6" />

        <!-- Inner wave -->
        <path
            android:strokeColor="#FFFFFF"
            android:strokeWidth="11.2"
            android:strokeLineCap="round"
            android:strokeLineJoin="round"
            android:pathData="M119.52,111.12 C124,99.92 135.2,103.28 135.2,110 C135.2,116.72 124,122.32 119.52,127.92" />
    </group>
</vector>
