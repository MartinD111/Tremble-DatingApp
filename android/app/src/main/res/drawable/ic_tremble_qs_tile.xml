<!--
  Official Tremble logo for the Quick Settings tile.
  Android tints this with the system accent colour at runtime.
  Viewport matched to source SVG (220x220) for path fidelity.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="220"
    android:viewportHeight="220">

    <group
        android:translateX="110"
        android:translateY="110"
        android:scaleX="1.12"
        android:scaleY="1.12">
        <group
            android:translateX="-3.5"
            android:translateY="-20">
            
            <!-- Main curve -->
            <path
                android:strokeColor="#FFFFFF"
                android:strokeWidth="11"
                android:strokeLineCap="round"
                android:pathData="M -4,70 C -34,60 -64,30 -64,0 C -64,-35 -34,-50 -4,-20" />

            <!-- Waves -->
            <path
                android:strokeColor="#FFFFFF"
                android:strokeWidth="11"
                android:strokeLineCap="round"
                android:pathData="M 12,-20 C 42,-50 72,-35 72,0 C 72,30 42,60 12,70" />

            <path
                android:strokeColor="#FFFFFF"
                android:strokeWidth="11"
                android:strokeLineCap="round"
                android:pathData="M 12,5 C 29,-15 46,-5 46,12 C 46,28 29,42 12,50" />

            <path
                android:strokeColor="#FFFFFF"
                android:strokeWidth="11"
                android:strokeLineCap="round"
                android:pathData="M 12,21 C 16,11 26,14 26,20 C 26,26 16,31 12,36" />
        </group>
    </group>
</vector>
