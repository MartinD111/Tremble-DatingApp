<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Foreground service -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE"/>
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC"/>
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION"/>
    <!-- Required on Android 14+ when foregroundServiceType includes
         "connectedDevice" (BLE radar). Android throws SecurityException at
         startForeground() time without this. Both the plugin service and our
         RadarForegroundService trampoline declare this type. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CONNECTED_DEVICE"/>

    <!-- BLE permissions (Android 12+) -->
    <uses-permission android:name="android.permission.BLUETOOTH_SCAN"
        android:usesPermissionFlags="neverForLocation"/>
    <uses-permission android:name="android.permission.BLUETOOTH_ADVERTISE"/>
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT"/>
    <!-- BLE legacy (Android < 12) -->
    <uses-permission android:name="android.permission.BLUETOOTH"/>
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN"/>

    <!-- Location permissions -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION"/>
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION"/>
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION"/>

    <!-- ── flutter_ble_peripheral 2.1.0 duplicate-permission blockade ────
         The plugin's manifest declares ACCESS_FINE_LOCATION and
         ACCESS_COARSE_LOCATION as <uses-permission-sdk-23 maxSdkVersion="30">.
         The Gradle manifest merger treats <uses-permission-sdk-23> and
         <uses-permission> as distinct elements and does NOT deduplicate
         them, so both variants end up in the final APK with divergent
         maxSdkVersion values — triggering Play Console "Sensitive
         permissions" review inconsistencies.

         tools:node="remove" on the matching <uses-permission-sdk-23>
         element instructs the merger to drop the plugin's entries.
         Runtime location grant is unaffected: the plain <uses-permission>
         declarations above still cover all API levels.

         Verify after build by grepping merged manifest at
         build/app/intermediates/merged_manifests/prodRelease/
         processProdReleaseManifest/AndroidManifest.xml — no
         uses-permission-sdk-23 entries should remain.

         If flutter_ble_peripheral is upgraded and drops the sdk-23
         pattern, this blockade becomes a silent no-op (harmless). Same
         brittleness as the flutter_background_service receiver blockade
         below.
    -->
    <uses-permission-sdk-23
        android:name="android.permission.ACCESS_FINE_LOCATION"
        tools:node="remove" />
    <uses-permission-sdk-23
        android:name="android.permission.ACCESS_COARSE_LOCATION"
        tools:node="remove" />

    <!-- Activity Recognition (Run Club) -->
    <uses-permission android:name="android.permission.ACTIVITY_RECOGNITION"/>

    <!-- Internet for Firebase -->
    <uses-permission android:name="android.permission.INTERNET"/>
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED"/>
    <uses-permission android:name="com.android.vending.BILLING"/>

    <!-- Notifications (Android 13+ runtime grant required) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>

    <!-- BLE hardware feature (optional — allows non-BLE devices to still install) -->
    <uses-feature android:name="android.hardware.bluetooth_le" android:required="false"/>

    <!-- Camera + photo library (profile photos in onboarding and edit profile) -->
    <uses-permission android:name="android.permission.CAMERA"/>
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES"/>
    <uses-permission android:name="android.permission.READ_MEDIA_VIDEO"/>
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32"/>

    <application
        android:label="Tremble"
        android:name=".MainApplication"
        android:icon="@mipmap/launcher_icon"
        android:enableOnBackInvokedCallback="true">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"
              />
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />

        <!-- ── FCM default notification channel + icon ──────────────────────
             Used when an incoming FCM notification message omits an explicit
             channel_id. Must match a channel created in NotificationService
             (see lib/src/core/notification_service.dart — 'tremble_wave').
        -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_channel_id"
            android:value="tremble_wave"/>
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_icon"
            android:resource="@mipmap/ic_launcher"/>

        <service
            android:name="id.flutter.flutter_background_service.BackgroundService"
            android:foregroundServiceType="dataSync|location|connectedDevice"
            />

        <!-- ── flutter_background_service auto-restart blockade ─────────────
             The plugin's manifest auto-merges two receivers into our app:
               - WatchdogReceiver: schedules a 5s alarm on every onStartCommand
                 and respawns BackgroundService directly via
                 ContextCompat.startForegroundService(BackgroundService.class)
                 — bypassing our RadarForegroundService trampoline. This is
                 the cause of the recurring ForegroundServiceDidNotStartInTime
                 crash on app open / process revival.
               - BootReceiver: same direct-start pattern after device boot or
                 package replacement.
             Both must be removed from the merged manifest. Our trampoline is
             the only legitimate entry-point for BackgroundService. The plugin
             still works in foreground mode because we relay-start it through
             RadarForegroundService.start() while the trampoline holds the
             foreground notification on NOTIF_ID 888.

             tools:node="remove" instructs the manifest merger to drop these
             nodes entirely. Verified by inspecting build/intermediates/
             merged_manifests/.../AndroidManifest.xml after build.

             If the plugin is upgraded and either receiver is renamed, this
             blockade silently stops working. See lessons.md Rule on this
             handoff brittleness.
        -->
        <receiver
            android:name="id.flutter.flutter_background_service.WatchdogReceiver"
            tools:node="remove" />
        <receiver
            android:name="id.flutter.flutter_background_service.BootReceiver"
            tools:node="remove" />

        <!-- ── Radar trampoline foreground service ──────────────────────────
             Started by MainActivity (via MethodChannel) and by the QS tile /
             widget toggle paths. Calls startForeground() synchronously on the
             first line of onStartCommand so Android's 5s deadline is always
             met, then relay-starts the flutter_background_service plugin
             service to host the Dart isolate. See RadarForegroundService.kt.
        -->
        <service
            android:name=".radar.RadarForegroundService"
            android:exported="false"
            android:foregroundServiceType="dataSync|location|connectedDevice"
            />

        <!-- ── Quick Settings tile ───────────────────────────────────────── -->
        <service
            android:name=".radar.RadarTileService"
            android:exported="true"
            android:label="@string/qs_tile_label"
            android:icon="@drawable/ic_tremble_qs_tile"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        <!-- ── Home / lock-screen widget ────────────────────────────────── -->
        <receiver
            android:name=".radar.RadarWidgetProvider"
            android:exported="true"
            android:label="@string/widget_label">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_radar_info" />
        </receiver>

        <!-- ── Gym Mode native geofence receiver ────────────────────────── -->
        <!-- Woken by GeofencingClient PendingIntent on DWELL event.        -->
        <!-- Works when app is killed — no Flutter engine required.         -->
        <receiver
            android:name=".gym.GymGeofenceReceiver"
            android:exported="false" />

        <!-- ── Radar toggle broadcast receiver (widget tap + tile) ──────── -->
        <receiver
            android:name=".radar.RadarToggleReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="app.tremble.action.RADAR_TOGGLE" />
            </intent-filter>
        </receiver>

    </application>

    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
    </queries>
</manifest>
