{
  "version": 8,
  "name": "Tremble Premium Light",
  "metadata": {
    "tremble:version": "2.0.0",
    "tremble:description": "Flat light Apple Maps-inspired style with progressive disclosure and subtle glassmorphism"
  },
  "sources": {
    "protomaps": {
      "type": "vector",
      "url": "pmtiles://https://maps.trembledating.com/planet.pmtiles"
    }
  },
  "sprite": "https://protomaps.github.io/basemaps-assets/sprites/v4/light",
  "glyphs": "https://protomaps.github.io/basemaps-assets/fonts/{fontstack}/{range}.pbf",
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": {
        "background-color": "#F8F7F3"
      }
    },
    {
      "id": "earth",
      "type": "fill",
      "source": "protomaps",
      "source-layer": "earth",
      "paint": {
        "fill-color": "#F4F1E9"
      }
    },
    {
      "id": "landuse_residential",
      "type": "fill",
      "source": "protomaps",
      "source-layer": "landuse",
      "minzoom": 8,
      "filter": ["in", "kind", "residential", "suburb"],
      "paint": {
        "fill-color": "#F2EFE8",
        "fill-opacity": 0.55
      }
    },
    {
      "id": "landuse_commercial",
      "type": "fill",
      "source": "protomaps",
      "source-layer": "landuse",
      "minzoom": 8,
      "filter": ["in", "kind", "commercial", "retail", "industrial", "university", "school", "hospital"],
      "paint": {
        "fill-color": "#EEEADF",
        "fill-opacity": 0.5
      }
    },
    {
      "id": "landuse_parks",
      "type": "fill",
      "source": "protomaps",
      "source-layer": "landuse",
      "minzoom": 6,
      "filter": ["in", "kind", "park", "forest", "wood", "meadow", "nature_reserve", "garden", "golf_course", "grass", "cemetery", "recreation_ground"],
      "paint": {
        "fill-color": "#D8E0D0",
        "fill-opacity": 0.72
      }
    },
    {
      "id": "natural_wood",
      "type": "fill",
      "source": "protomaps",
      "source-layer": "natural",
      "minzoom": 6,
      "filter": ["in", "kind", "wood", "forest", "scrub", "heath", "grassland"],
      "paint": {
        "fill-color": "#D3DCC7",
        "fill-opacity": 0.72
      }
    },
    {
      "id": "natural_sand",
      "type": "fill",
      "source": "protomaps",
      "source-layer": "natural",
      "minzoom": 8,
      "filter": ["==", "kind", "sand"],
      "paint": {
        "fill-color": "#E9DDC8",
        "fill-opacity": 0.5
      }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "protomaps",
      "source-layer": "water",
      "paint": {
        "fill-color": "#C5D6E6"
      }
    },
    {
      "id": "water_lines",
      "type": "line",
      "source": "protomaps",
      "source-layer": "water",
      "filter": ["==", "$type", "LineString"],
      "paint": {
        "line-color": "#C5D6E6",
        "line-width": [
          "interpolate",
          ["linear"],
          ["zoom"],
          10,
          0.35,
          16,
          2
        ],
        "line-opacity": 0.7
      }
    },
    {
      "id": "buildings-flat",
      "type": "fill",
      "source": "protomaps",
      "source-layer": "buildings",
      "maxzoom": 15,
      "paint": {
        "fill-color": "#E6E1D8",
        "fill-opacity": 0.6
      }
    },
    {
      "id": "buildings-3d",
      "type": "fill-extrusion",
      "source": "protomaps",
      "source-layer": "buildings",
      "minzoom": 15,
      "paint": {
        "fill-extrusion-color": [
          "interpolate",
          ["linear"],
          ["zoom"],
          15,
          "#E5DFD5",
          17,
          "#DAD4CA"
        ],
        "fill-extrusion-height": [
          "coalesce",
          ["get", "height"],
          ["*", ["coalesce", ["get", "levels"], 1], 3.5],
          10
        ],
        "fill-extrusion-base": [
          "coalesce",
          ["get", "min_height"],
          ["*", ["coalesce", ["get", "min_levels"], 0], 3.5],
          0
        ],
        "fill-extrusion-opacity": 0.26
      }
    },
    {
      "id": "boundaries",
      "type": "line",
      "source": "protomaps",
      "source-layer": "boundaries",
      "maxzoom": 14,
      "paint": {
        "line-color": "#D7D3CA",
        "line-width": [
          "interpolate",
          ["linear"],
          ["zoom"],
          3,
          0.25,
          10,
          1
        ],
        "line-opacity": 0.55
      }
    },
    {
      "id": "roads_casing",
      "type": "line",
      "source": "protomaps",
      "source-layer": "roads",
      "minzoom": 6,
      "filter": ["in", "kind", "motorway", "trunk", "primary", "secondary"],
      "paint": {
        "line-color": "#D1CCC2",
        "line-width": [
          "interpolate",
          ["linear"],
          ["zoom"],
          6,
          1.1,
          18,
          10.5
        ],
        "line-opacity": 0.5
      }
    },
    {
      "id": "roads_highway",
      "type": "line",
      "source": "protomaps",
      "source-layer": "roads",
      "minzoom": 6,
      "filter": ["in", "kind", "motorway", "trunk"],
      "paint": {
        "line-color": "#FFFFFF",
        "line-width": [
          "interpolate",
          ["linear"],
          ["zoom"],
          6,
          0.9,
          18,
          9.5
        ],
        "line-opacity": 0.95
      }
    },
    {
      "id": "roads_major",
      "type": "line",
      "source": "protomaps",
      "source-layer": "roads",
      "minzoom": 9.5,
      "filter": ["in", "kind", "primary", "secondary"],
      "paint": {
        "line-color": "#FFFFFF",
        "line-width": [
          "interpolate",
          ["linear"],
          ["zoom"],
          9.5,
          0.7,
          18,
          6.8
        ],
        "line-opacity": 0.92
      }
    },
    {
      "id": "roads_minor",
      "type": "line",
      "source": "protomaps",
      "source-layer": "roads",
      "minzoom": 12,
      "filter": ["in", "kind", "tertiary", "residential", "unclassified", "service"],
      "paint": {
        "line-color": "#FFFFFF",
        "line-width": [
          "interpolate",
          ["linear"],
          ["zoom"],
          12,
          0.4,
          18,
          3.2
        ],
        "line-opacity": 0.88
      }
    },
    {
      "id": "roads_paths",
      "type": "line",
      "source": "protomaps",
      "source-layer": "roads",
      "minzoom": 14,
      "filter": ["in", "kind", "path", "footway", "cycleway", "pedestrian"],
      "paint": {
        "line-color": "#DAD6CE",
        "line-width": [
          "interpolate",
          ["linear"],
          ["zoom"],
          14,
          0.3,
          18,
          1
        ],
        "line-dasharray": [1.5, 1.5],
        "line-opacity": 0.55
      }
    },
    {
      "id": "transit_lines",
      "type": "line",
      "source": "protomaps",
      "source-layer": "transit",
      "minzoom": 12,
      "filter": ["==", "kind", "rail"],
      "paint": {
        "line-color": "#D3DAE4",
        "line-width": [
          "interpolate",
          ["linear"],
          ["zoom"],
          12,
          0.35,
          18,
          1.6
        ],
        "line-dasharray": [3, 3],
        "line-opacity": 0.4
      }
    },
    {
      "id": "place_country",
      "type": "symbol",
      "source": "protomaps",
      "source-layer": "places",
      "minzoom": 1.5,
      "maxzoom": 6.5,
      "filter": ["==", "kind", "country"],
      "layout": {
        "text-field": ["coalesce", ["get", "name:en"], ["get", "name"]],
        "text-font": ["Noto Sans Bold"],
        "text-size": [
          "interpolate",
          ["linear"],
          ["zoom"],
          2,
          10,
          6,
          18
        ],
        "text-transform": "uppercase",
        "text-letter-spacing": 0.12
      },
      "paint": {
        "text-color": "#3F3E39",
        "text-halo-color": "#F8F7F3",
        "text-halo-width": 1.4
      }
    },
    {
      "id": "place_region",
      "type": "symbol",
      "source": "protomaps",
      "source-layer": "places",
      "minzoom": 4,
      "maxzoom": 9,
      "filter": ["==", "kind", "state"],
      "layout": {
        "text-field": ["coalesce", ["get", "name:en"], ["get", "name"]],
        "text-font": ["Noto Sans Regular"],
        "text-size": [
          "interpolate",
          ["linear"],
          ["zoom"],
          4,
          8.5,
          8,
          13
        ],
        "text-transform": "uppercase",
        "text-letter-spacing": 0.08
      },
      "paint": {
        "text-color": "#5A5954",
        "text-halo-color": "#F8F7F3",
        "text-halo-width": 1.1
      }
    },
    {
      "id": "place_capital",
      "type": "symbol",
      "source": "protomaps",
      "source-layer": "places",
      "minzoom": 4,
      "maxzoom": 14,
      "filter": ["==", "capital", 2],
      "layout": {
        "text-field": ["coalesce", ["get", "name:en"], ["get", "name"]],
        "text-font": ["Noto Sans Bold"],
        "text-size": [
          "interpolate", ["linear"], ["zoom"],
          4, 11,
          10, 16
        ],
        "text-letter-spacing": 0.05
      },
      "paint": {
        "text-color": "#1A1A18",
        "text-halo-color": "#F8F7F3",
        "text-halo-width": 1.6
      }
    },
    {
      "id": "place_city",
      "type": "symbol",
      "source": "protomaps",
      "source-layer": "places",
      "minzoom": 8,
      "maxzoom": 13.5,
      "filter": ["in", "kind", "city", "town"],
      "layout": {
        "text-field": ["coalesce", ["get", "name:en"], ["get", "name"]],
        "text-font": ["Noto Sans Bold"],
        "text-size": [
          "interpolate",
          ["linear"],
          ["zoom"],
          8,
          10,
          16,
          17.5
        ]
      },
      "paint": {
        "text-color": "#2B2A27",
        "text-halo-color": "#F8F7F3",
        "text-halo-width": 1
      }
    },
    {
      "id": "place_suburb",
      "type": "symbol",
      "source": "protomaps",
      "source-layer": "places",
      "minzoom": 12,
      "maxzoom": 16.5,
      "filter": ["in", "kind", "suburb", "neighbourhood", "village"],
      "layout": {
        "text-field": ["coalesce", ["get", "name:en"], ["get", "name"]],
        "text-font": ["Noto Sans Regular"],
        "text-size": [
          "interpolate",
          ["linear"],
          ["zoom"],
          12,
          8.5,
          16,
          12.5
        ]
      },
      "paint": {
        "text-color": "#4C4A46",
        "text-halo-color": "#F8F7F3",
        "text-halo-width": 0.8
      }
    },
    {
      "id": "road_labels",
      "type": "symbol",
      "source": "protomaps",
      "source-layer": "roads",
      "minzoom": 13.5,
      "filter": ["in", "kind", "motorway", "trunk", "primary", "secondary", "tertiary"],
      "layout": {
        "text-field": ["get", "name"],
        "text-font": ["Noto Sans Regular"],
        "text-size": [
          "interpolate",
          ["linear"],
          ["zoom"],
          13.5,
          8.5,
          16,
          11.5
        ],
        "symbol-placement": "line",
        "text-rotation-alignment": "map"
      },
      "paint": {
        "text-color": "#4B4842",
        "text-halo-color": "#F8F7F3",
        "text-halo-width": 1
      }
    },
    {
      "id": "pois",
      "type": "symbol",
      "source": "protomaps",
      "source-layer": "pois",
      "minzoom": 15.5,
      "layout": {
        "text-field": ["get", "name"],
        "text-font": ["Noto Sans Regular"],
        "text-size": [
          "interpolate",
          ["linear"],
          ["zoom"],
          15.5,
          8.5,
          18,
          10.5
        ],
        "text-offset": [0, 0.55],
        "text-anchor": "top"
      },
      "paint": {
        "text-color": "#2B2A27",
        "text-halo-color": "#F8F7F3",
        "text-halo-width": 1
      }
    }
  ]
}
